<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.esports.controller.PanierController"
            style="-fx-background-color: #0d0b1e;">

    <stylesheets>
        <URL value="@../css/home.css"/>
    </stylesheets>

    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="N" style="-fx-background-color: #a855f7; -fx-text-fill: white;
                       -fx-font-size: 15px; -fx-font-weight: bold;
                       -fx-background-radius: 6px; -fx-padding: 4 9 4 9;"/>
                <Label text="NexUS" style="-fx-text-fill: white; -fx-font-size: 18px;
                       -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Boutique" onAction="#onBackShop" styleClass="nav-link"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background: #0d0b1e; -fx-background-color: #0d0b1e; -fx-border-color: transparent;">
            <VBox style="-fx-background-color: #0d0b1e; -fx-padding: 40 80 60 80;" spacing="24">

                <!-- TITRE -->
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="🛒" style="-fx-font-size: 32px;"/>
                    <Label text="Mon Panier"
                           style="-fx-text-fill: white; -fx-font-size: 28px;
                                  -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
                    <Label fx:id="lblNombreArticles" text="(0 article)"
                           style="-fx-text-fill: #9ca3af; -fx-font-size: 16px;"/>
                </HBox>

                <!-- PANIER VIDE -->
                <VBox fx:id="vboxVide" alignment="CENTER" spacing="16"
                      style="-fx-padding: 60 0 60 0;" visible="true" managed="true">
                    <Label text="🛒" style="-fx-font-size: 64px;"/>
                    <Label text="Votre panier est vide"
                           style="-fx-text-fill: #9ca3af; -fx-font-size: 18px;"/>
                    <Button text="Continuer mes achats" onAction="#onBackShop"
                            style="-fx-background-color: linear-gradient(to right, #7c3aed, #ec4899);
                                   -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;
                                   -fx-background-radius: 10px; -fx-padding: 12 30 12 30; -fx-cursor: hand;"/>
                </VBox>

                <!-- CONTENU PANIER -->
                <HBox fx:id="hboxContenu" spacing="32" visible="false" managed="false">

                    <!-- LISTE ARTICLES -->
                    <VBox fx:id="vboxItems" spacing="16" HBox.hgrow="ALWAYS"/>

                    <!-- RÉSUMÉ COMMANDE -->
                    <VBox spacing="16" minWidth="300" maxWidth="300"
                          style="-fx-background-color: rgba(20,17,43,0.9);
                                 -fx-border-color: rgba(139,92,246,0.22);
                                 -fx-border-width: 1.5px; -fx-border-radius: 14px;
                                 -fx-background-radius: 14px; -fx-padding: 24;
                                 -fx-alignment: TOP_LEFT;">

                        <Label text="Résumé de la commande"
                               style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>

                        <HBox>
                            <Label text="Sous-total" style="-fx-text-fill: #9ca3af; -fx-font-size: 14px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblSousTotal" text="0 DT"
                                   style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                        </HBox>

                        <HBox>
                            <Label text="Livraison" style="-fx-text-fill: #9ca3af; -fx-font-size: 14px;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="Gratuite" style="-fx-text-fill: #4ade80; -fx-font-size: 14px;"/>
                        </HBox>

                        <Label style="-fx-border-color: rgba(139,92,246,0.2); -fx-border-width: 1px 0 0 0; -fx-min-height: 1px;"/>

                        <HBox>
                            <Label text="TOTAL" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblTotal" text="0 DT"
                                   style="-fx-text-fill: #a855f7; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                        </HBox>

                        <Button text="✓ Commander" onAction="#onCommander" maxWidth="Infinity"
                                style="-fx-background-color: linear-gradient(to right, #7c3aed, #ec4899);
               -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;
               -fx-background-radius: 10px; -fx-padding: 14 0 14 0; -fx-cursor: hand;"/>

                        <Button text="🗑 Vider le panier" onAction="#onVider" maxWidth="Infinity"
                                style="-fx-background-color: rgba(248,113,113,0.1);
                                       -fx-text-fill: #f87171; -fx-font-size: 13px;
                                       -fx-border-color: rgba(248,113,113,0.4); -fx-border-width: 1px;
                                       -fx-border-radius: 8px; -fx-background-radius: 8px;
                                       -fx-padding: 10 0 10 0; -fx-cursor: hand;"/>
                    </VBox>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
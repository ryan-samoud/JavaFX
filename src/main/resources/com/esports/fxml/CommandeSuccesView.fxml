<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.esports.controller.CommandeSuccesController"
            style="-fx-background-color: #0d0b1e;">
    <stylesheets>
        <URL value="@../css/home.css"/>
    </stylesheets>

    <center>
        <VBox alignment="CENTER" spacing="24"
              style="-fx-background-color: #0d0b1e; -fx-padding: 60 80 60 80;">

            <!-- Icône succès -->
            <Label text="✅" style="-fx-font-size: 72px;"/>

            <Label text="Commande confirmée !"
                   style="-fx-text-fill: white; -fx-font-size: 32px;
                          -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>

            <Label text="Merci pour votre achat. Votre commande est en cours de traitement."
                   style="-fx-text-fill: #9ca3af; -fx-font-size: 15px;"/>

            <!-- Reçu -->
            <VBox spacing="16" maxWidth="500"
                  style="-fx-background-color: rgba(20,17,43,0.9);
                         -fx-border-color: rgba(139,92,246,0.22);
                         -fx-border-width: 1.5px; -fx-border-radius: 14px;
                         -fx-background-radius: 14px; -fx-padding: 28;">

                <HBox alignment="CENTER">
                    <Label text="🧾 Reçu de paiement"
                           style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                </HBox>

                <HBox>
                    <Label text="Référence" style="-fx-text-fill: #9ca3af; -fx-font-size: 14px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblReference"
                           style="-fx-text-fill: #a855f7; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </HBox>

                <HBox>
                    <Label text="Date" style="-fx-text-fill: #9ca3af; -fx-font-size: 14px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblDate" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                </HBox>

                <HBox>
                    <Label text="Mode de paiement" style="-fx-text-fill: #9ca3af; -fx-font-size: 14px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblModePaiement" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                </HBox>

                <HBox>
                    <Label text="Adresse" style="-fx-text-fill: #9ca3af; -fx-font-size: 14px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblAdresse" style="-fx-text-fill: white; -fx-font-size: 14px;"
                           wrapText="true" maxWidth="220"/>
                </HBox>

                <Label style="-fx-border-color: rgba(139,92,246,0.2);
                              -fx-border-width: 1px 0 0 0; -fx-min-height: 1px;"/>

                <HBox>
                    <Label text="TOTAL PAYÉ" style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblTotal"
                           style="-fx-text-fill: #4ade80; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                </HBox>

                <Label fx:id="lblStatut" text="● Paiement validé"
                       style="-fx-text-fill: #4ade80; -fx-font-size: 13px; -fx-font-weight: bold;"/>
            </VBox>

            <!-- Boutons -->
            <HBox spacing="16" alignment="CENTER">
                <Button text="🛍️ Continuer mes achats" onAction="#onContinuer"
                        style="-fx-background-color: linear-gradient(to right, #7c3aed, #ec4899);
                               -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold;
                               -fx-background-radius: 10px; -fx-padding: 13 30 13 30; -fx-cursor: hand;"/>
                <Button text="🏠 Accueil" onAction="#onAccueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #c4b5fd;
                               -fx-border-color: rgba(139,92,246,0.5); -fx-border-width: 1.5px;
                               -fx-border-radius: 10px; -fx-background-radius: 10px;
                               -fx-font-size: 14px; -fx-padding: 12 30 12 30; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
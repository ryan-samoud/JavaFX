<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<ScrollPane fitToWidth="true" fitToHeight="true"
            hbarPolicy="NEVER" vbarPolicy="NEVER"
            minWidth="1280" minHeight="800"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.esports.controller.ResetPasswordController"
            styleClass="home-scroll">

    <stylesheets>
        <URL value="@../css/home.css"/>
        <URL value="@../css/register.css"/>
    </stylesheets>

    <VBox styleClass="home-root" spacing="0" minWidth="1280" minHeight="800">

        <!-- NAVBAR -->
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="N" style="-fx-background-color: #a855f7; -fx-text-fill: white;
                       -fx-font-size: 15px; -fx-font-weight: bold;
                       -fx-background-radius: 6px; -fx-padding: 4 9 4 9;
                       -fx-effect: dropshadow(gaussian, rgba(168,85,247,0.8), 10, 0.4, 0, 0);"/>
                <Label text="NexUS" style="-fx-text-fill: white; -fx-font-size: 18px;
                       -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- FORM -->
        <VBox alignment="CENTER" spacing="20" VBox.vgrow="ALWAYS"
              style="-fx-background-color: linear-gradient(to bottom, #100c2a, #1a0a3e 45%, #0d0b1e);
                     -fx-padding: 60 40 60 40;">

            <Label text="NOUVEAU MOT DE PASSE" styleClass="section-title-center"/>
            <Label text="Choisissez un nouveau mot de passe sécurisé (8 caractères minimum)"
                   styleClass="section-subtitle-center" wrapText="true"
                   style="-fx-text-alignment: center;"/>

            <VBox spacing="14" maxWidth="380">

                <VBox spacing="4">
                    <Label text="Nouveau mot de passe" styleClass="field-label"/>
                    <PasswordField fx:id="fieldNewPassword"
                                  promptText="Minimum 8 caractères"
                                  styleClass="input-field"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Confirmer le mot de passe" styleClass="field-label"/>
                    <PasswordField fx:id="fieldConfirmPassword"
                                  promptText="Répétez le mot de passe"
                                  styleClass="input-field"/>
                </VBox>

                <Label fx:id="lblError"   styleClass="error-label"     wrapText="true"/>
                <Label fx:id="lblSuccess"
                       style="-fx-text-fill: #4ade80; -fx-font-size: 13px; -fx-font-weight: bold;"
                       wrapText="true"/>

                <Button fx:id="btnReset"
                        text="RÉINITIALISER LE MOT DE PASSE"
                        onAction="#onReset"
                        styleClass="btn-neon"
                        maxWidth="Infinity"/>

            </VBox>
        </VBox>

    </VBox>
</ScrollPane>
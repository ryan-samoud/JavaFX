<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17"
      fx:controller="com.esports.controller.CategoryFormController"
      spacing="0" style="-fx-background-color: #0d0b1e; -fx-border-color: #a855f7; -fx-border-width: 2; -fx-border-radius: 12; -fx-background-radius: 12;"
      prefWidth="450">

    <stylesheets>
        <URL value="@../css/dashboard.css"/>
    </stylesheets>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #14112b; -fx-padding: 20; -fx-background-radius: 12 12 0 0;">
        <Label fx:id="lblHeaderIcon" text="📂" style="-fx-font-size: 24;"/>
        <Label fx:id="lblHeaderTitle" text="Ajouter une Catégorie" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
    </HBox>

    <VBox spacing="18" style="-fx-padding: 25;">
        
        <VBox spacing="6">
            <Label text="Nom de la Catégorie *" style="-fx-text-fill: #9ca3af; -fx-font-weight: bold;"/>
            <TextField fx:id="fieldNom" styleClass="modern-field" prefHeight="45" promptText="Ex: Compétitif"/>
            <Label fx:id="errNom" text="Champ obligatoire" style="-fx-text-fill: #f87171; -fx-font-size: 11;" visible="false" managed="false"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Genre / Icône (Emoji)" style="-fx-text-fill: #9ca3af; -fx-font-weight: bold;"/>
            <TextField fx:id="fieldGenre" styleClass="modern-field" prefHeight="45" promptText="Ex: 💥"/>
        </VBox>

    </VBox>

    <!-- Footer -->
    <HBox alignment="CENTER_RIGHT" spacing="15" style="-fx-background-color: #14112b; -fx-padding: 20; -fx-background-radius: 0 0 12 12;">
        <Button text="Annuler" onAction="#onCancel" styleClass="btn-outline-sm" prefHeight="40" prefWidth="100"/>
        <Button fx:id="btnSubmit" text="Enregistrer" onAction="#onSubmit" styleClass="btn-primary" prefHeight="40" prefWidth="140"/>
    </HBox>
</VBox>

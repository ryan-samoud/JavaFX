<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<ScrollPane fitToWidth="true" fitToHeight="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            minWidth="1280" minHeight="800"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.esports.controller.ProfileController"
            styleClass="home-scroll">

    <stylesheets>
        <URL value="@../css/home.css"/>
        <URL value="@../css/register.css"/>
    </stylesheets>

    <VBox styleClass="home-root" spacing="0" minWidth="1280" minHeight="800">

        <!-- NAVBAR -->
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="N" style="-fx-background-color: #a855f7; -fx-text-fill: white;
                       -fx-font-size: 15px; -fx-font-weight: bold;
                       -fx-background-radius: 6px; -fx-padding: 4 9 4 9;"/>
                <Label text="NexUS" style="-fx-text-fill: white; -fx-font-size: 18px;
                       -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Retour" onAction="#onBack" styleClass="btn-outline-sm"/>
        </HBox>

        <!-- PROFILE CARD -->
        <VBox styleClass="login-section" alignment="CENTER" spacing="30" VBox.vgrow="ALWAYS">

            <!-- Avatar grand / Photo -->
            <StackPane alignment="CENTER">
                <Label fx:id="lblAvatarBig"
                       text=""
                       style="-fx-background-color: linear-gradient(to bottom right,#7c3aed,#ec4899);
                              -fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: bold;
                              -fx-background-radius: 50%; -fx-alignment: center;
                              -fx-min-width: 90px; -fx-min-height: 90px;
                              -fx-max-width: 90px; -fx-max-height: 90px;
                              -fx-effect: dropshadow(gaussian,rgba(168,85,247,0.7),20,0.4,0,0);"/>
                <ImageView fx:id="imgPhoto"
                           fitWidth="90" fitHeight="90"
                           preserveRatio="false"
                           visible="false"/>
            </StackPane>

            <Label fx:id="lblFullName"
                   text=""
                   style="-fx-text-fill: white; -fx-font-size: 26px; -fx-font-weight: bold;"/>

            <Label fx:id="lblRole"
                   text=""
                   style="-fx-text-fill: #a855f7; -fx-font-size: 14px; -fx-font-weight: bold;"/>

            <!-- Info card -->
            <VBox spacing="16" maxWidth="420"
                  style="-fx-background-color: rgba(26,18,58,0.85);
                         -fx-border-color: rgba(139,92,246,0.25);
                         -fx-border-width: 1.5px; -fx-border-radius: 14px;
                         -fx-background-radius: 14px; -fx-padding: 28 32 28 32;">

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="📧" style="-fx-font-size: 16px;"/>
                    <VBox spacing="2">
                        <Label text="Email" styleClass="field-label"/>
                        <Label fx:id="lblEmail"
                               style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                    </VBox>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="🎂" style="-fx-font-size: 16px;"/>
                    <VBox spacing="2">
                        <Label text="Âge" styleClass="field-label"/>
                        <Label fx:id="lblAge"
                               style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                    </VBox>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="🏷" style="-fx-font-size: 16px;"/>
                    <VBox spacing="2">
                        <Label text="Type de compte" styleClass="field-label"/>
                        <Label fx:id="lblRoleDetail"
                               style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                    </VBox>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="📅" style="-fx-font-size: 16px;"/>
                    <VBox spacing="2">
                        <Label text="Membre depuis" styleClass="field-label"/>
                        <Label fx:id="lblDate"
                               style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                    </VBox>
                </HBox>

            </VBox>

            <Button text="✏  Modifier mon profil"
                    onAction="#onEdit"
                    styleClass="btn-neon"
                    style="-fx-padding: 10 28 10 28;"/>

            <Button text="Se déconnecter"
                    onAction="#onLogout"
                    style="-fx-background-color: rgba(248,113,113,0.15);
                           -fx-text-fill: #f87171;
                           -fx-border-color: rgba(248,113,113,0.5);
                           -fx-border-width: 1.5px; -fx-border-radius: 8px;
                           -fx-background-radius: 8px; -fx-font-size: 13px;
                           -fx-font-weight: bold; -fx-padding: 10 28 10 28;
                           -fx-cursor: hand;"/>

        </VBox>
    </VBox>
</ScrollPane>
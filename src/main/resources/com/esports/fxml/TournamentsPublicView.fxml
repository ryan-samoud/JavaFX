<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           xmlns="http://javafx.com/javafx/17"
           fx:controller="com.esports.controller.TournamentsPublicController"
           style="-fx-background-color: #0d0b1e;">

    <stylesheets>
        <URL value="@../css/home.css"/>
    </stylesheets>

    <!-- 1. LA PAGE PRINCIPALE (SCROLLABLE) -->
    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                style="-fx-background: #0d0b1e; -fx-background-color: #0d0b1e; -fx-border-color: transparent;">
        
        <VBox style="-fx-background-color: #0d0b1e;" spacing="0">

            <!-- NAVBAR -->
            <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">
                <HBox alignment="CENTER_LEFT" spacing="6">
                    <Label text="N"
                           style="-fx-background-color: #a855f7; -fx-text-fill: white;
                                  -fx-font-size: 15px; -fx-font-weight: bold;
                                  -fx-background-radius: 6px; -fx-padding: 4 9 4 9;
                                  -fx-effect: dropshadow(gaussian, rgba(168,85,247,0.8), 10, 0.4, 0, 0);"/>
                    <Label text="NexUS"
                           style="-fx-text-fill: white; -fx-font-size: 18px;
                                  -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Accueil" onAction="#onBackHome" styleClass="nav-link"/>
                <Button text="Jeux"    styleClass="nav-link"/>
                <Button text="Tournois"
                        style="-fx-background-color: rgba(168,85,247,0.12);
                               -fx-text-fill: #c084fc; -fx-font-size: 14px;
                               -fx-font-weight: bold; -fx-cursor: hand;
                               -fx-border-color: transparent transparent #a855f7 transparent;
                               -fx-border-width: 0 0 2 0;
                               -fx-padding: 7 14 5 14; -fx-background-radius: 6px;"/>
                <Button text="Boutique"    styleClass="nav-link"/>
                <Button text="Événements"  styleClass="nav-link"/>

                <Label text="🏆" style="-fx-font-size: 18px; -fx-cursor: hand;"/>
                <Label text="🛒" style="-fx-font-size: 18px; -fx-cursor: hand;"/>

                <Button text="Mes Inscriptions" onAction="#onGoToMyInscriptions"
                        style="-fx-background-color: transparent; -fx-text-fill: #ffaa00;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 7 14;"/>

                <Button text="🗺️ Explorer sur Carte" onAction="#onOpenGlobalMap"
                        style="-fx-background-color: rgba(139,92,246,0.12); -fx-text-fill: #a855f7;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 7 14;
                               -fx-border-color: rgba(139,92,246,0.3); -fx-border-radius: 6;
                               -fx-background-radius: 6;"/>

                <Button text="📅 Google Calendar" onAction="#onShowCalendar"
                        style="-fx-background-color: rgba(66,133,244,0.1); -fx-text-fill: #93c5fd;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 7 14;
                               -fx-border-color: rgba(66,133,244,0.3); -fx-border-radius: 6;
                               -fx-background-radius: 6;"/>

                <Button text="🔴 LIVE" onAction="#onStartLive"
                        style="-fx-background-color: rgba(239,68,68,0.1); -fx-text-fill: #ef4444;
                               -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;
                               -fx-border-color: #ef4444; -fx-border-radius: 6; -fx-padding: 7 14;"/>

                <Button text="Connexion"  onAction="#onBackHome" styleClass="btn-outline-sm"/>
            </HBox>

            <!-- HERO HEADER -->
            <VBox alignment="CENTER" spacing="12"
                  style="-fx-background-color: linear-gradient(to bottom, #100c2a, #1a0a3e 50%, #0d0b1e);
                         -fx-padding: 70 40 70 40; -fx-min-height: 280px;">

                <HBox alignment="CENTER" spacing="10">
                    <Rectangle width="4" height="36" arcWidth="2" arcHeight="2"
                               style="-fx-fill: linear-gradient(to bottom, #a855f7, #ec4899);"/>
                    <Label text="TOURNOIS"
                           style="-fx-text-fill: white; -fx-font-size: 40px;
                                  -fx-font-weight: bold; -fx-font-family: 'Arial Black';
                                  -fx-effect: dropshadow(gaussian, rgba(168,85,247,0.6), 20, 0.3, 0, 0);"/>
                </HBox>

                <Label text="Rejoignez les meilleurs tournois eSports et prouvez votre talent"
                       style="-fx-text-fill: #c4b5fd; -fx-font-size: 16px; -fx-padding: 0 0 10 0;"/>

                <HBox alignment="CENTER" spacing="14">
                    <TextField fx:id="fieldSearch"
                               promptText="🔍  Rechercher un tournoi…"
                               prefWidth="300"
                               style="-fx-background-color: rgba(26,18,58,0.9);
                                      -fx-text-fill: white; -fx-prompt-text-fill: #6b7280;
                                      -fx-border-color: rgba(139,92,246,0.4); -fx-border-width: 1.5px;
                                      -fx-border-radius: 8px; -fx-background-radius: 8px;
                                      -fx-font-size: 14px; -fx-padding: 11 16 11 16;"/>

                    <ComboBox fx:id="comboFilter" promptText="Tous les statuts"
                              style="-fx-background-color: rgba(26,18,58,0.9);
                                     -fx-text-fill: white; -fx-font-size: 13px;
                                     -fx-border-color: rgba(139,92,246,0.4); -fx-border-width: 1.5px;
                                     -fx-border-radius: 8px; -fx-background-radius: 8px;
                                     -fx-padding: 4 10 4 10;"/>

                    <Button text="Rechercher" onAction="#onSearch"
                            styleClass="btn-hero-primary"/>
                </HBox>

                <!-- Sélecteur de Devise -->
                <HBox alignment="CENTER" spacing="10" style="-fx-padding: 10 0 0 0;">
                    <Label text="Devise :" style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;"/>
                    <Button text="TND" onAction="#changeCurrencyTND" fx:id="btnTND"
                            style="-fx-background-color: rgba(168,85,247,0.1); -fx-text-fill: white; -fx-border-color: #a855f7; -fx-border-radius: 4; -fx-cursor: hand;"/>
                    <Button text="EUR" onAction="#changeCurrencyEUR" fx:id="btnEUR"
                            style="-fx-background-color: #a855f7; -fx-text-fill: white; -fx-border-color: #a855f7; -fx-border-radius: 4; -fx-cursor: hand;"/>
                    <Button text="USD" onAction="#changeCurrencyUSD" fx:id="btnUSD"
                            style="-fx-background-color: rgba(168,85,247,0.1); -fx-text-fill: white; -fx-border-color: #a855f7; -fx-border-radius: 4; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- STATS BAR -->
            <HBox alignment="CENTER" spacing="0"
                  style="-fx-background-color: #110f28;
                         -fx-border-color: transparent transparent rgba(139,92,246,0.15) transparent;
                         -fx-border-width: 0 0 1 0; -fx-padding: 20 40 20 40;">
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblTotalCount" text="—"
                           style="-fx-text-fill: #a855f7; -fx-font-size: 28px;
                                  -fx-font-weight: bold; -fx-font-family: 'Arial Black';
                                  -fx-effect: dropshadow(gaussian, rgba(168,85,247,0.5), 10, 0.2, 0, 0);"/>
                    <Label text="Tournois au total"
                           style="-fx-text-fill: #9ca3af; -fx-font-size: 12px;"/>
                </VBox>
                <Rectangle width="1" height="40" style="-fx-fill: rgba(139,92,246,0.2);"/>
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblOpenCount" text="—"
                           style="-fx-text-fill: #4ade80; -fx-font-size: 28px;
                                  -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
                    <Label text="Inscriptions ouvertes"
                           style="-fx-text-fill: #9ca3af; -fx-font-size: 12px;"/>
                </VBox>
                <Rectangle width="1" height="40" style="-fx-fill: rgba(139,92,246,0.2);"/>
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblUpcomingCount" text="—"
                           style="-fx-text-fill: #00b8ff; -fx-font-size: 28px;
                                  -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
                    <Label text="À venir"
                           style="-fx-text-fill: #9ca3af; -fx-font-size: 12px;"/>
                </VBox>
                <Rectangle width="1" height="40" style="-fx-fill: rgba(139,92,246,0.2);"/>
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblInProgressCount" text="—"
                           style="-fx-text-fill: #ec4899; -fx-font-size: 28px;
                                  -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
                    <Label text="En cours"
                           style="-fx-text-fill: #9ca3af; -fx-font-size: 12px;"/>
                </VBox>
            </HBox>

            <!-- GRILLE TOURNOIS -->
            <VBox spacing="30" style="-fx-background-color: #0d0b1e; -fx-padding: 50 60 70 60;">
                <Label fx:id="lblEmpty" text="Aucun tournoi disponible pour le moment."
                       visible="false" managed="false"
                       style="-fx-text-fill: #6b7280; -fx-font-size: 15px; -fx-alignment: CENTER;"/>

                <VBox spacing="14">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Circle radius="5" style="-fx-fill: #4ade80; -fx-effect: dropshadow(gaussian, rgba(74,222,128,0.8), 8, 0.4, 0, 0);"/>
                        <Label text="INSCRIPTIONS OUVERTES" style="-fx-text-fill: #4ade80; -fx-font-size: 13px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
                    </HBox>
                    <FlowPane fx:id="paneOpen" hgap="20" vgap="20" prefWrapLength="9999"/>
                </VBox>

                <VBox spacing="14">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Circle radius="5" style="-fx-fill: #00b8ff; -fx-effect: dropshadow(gaussian, rgba(0,184,255,0.8), 8, 0.4, 0, 0);"/>
                        <Label text="À VENIR" style="-fx-text-fill: #00b8ff; -fx-font-size: 13px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
                    </HBox>
                    <FlowPane fx:id="paneUpcoming" hgap="20" vgap="20" prefWrapLength="9999"/>
                </VBox>

                <VBox spacing="14">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Circle radius="5" style="-fx-fill: #ec4899; -fx-effect: dropshadow(gaussian, rgba(236,72,153,0.8), 8, 0.4, 0, 0);"/>
                        <Label text="EN COURS" style="-fx-text-fill: #ec4899; -fx-font-size: 13px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
                    </HBox>
                    <FlowPane fx:id="paneInProgress" hgap="20" vgap="20" prefWrapLength="9999"/>
                </VBox>

                <VBox spacing="14">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Circle radius="5" style="-fx-fill: #4b5563;"/>
                        <Label text="TERMINÉS" style="-fx-text-fill: #4b5563; -fx-font-size: 13px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
                    </HBox>
                    <FlowPane fx:id="paneFinished" hgap="20" vgap="20" prefWrapLength="9999"/>
                </VBox>
            </VBox>

            <!-- FOOTER -->
            <HBox alignment="CENTER" spacing="20"
                  style="-fx-background-color: #080714; -fx-border-color: rgba(139,92,246,0.15) transparent transparent transparent; -fx-border-width: 1 0 0 0; -fx-padding: 28 40 28 40;">
                <Label text="N" style="-fx-background-color: #a855f7; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 5px; -fx-padding: 3 8 3 8;"/>
                <Label text="NexUS Gaming Arena — Tous droits réservés" style="-fx-text-fill: #4b5563; -fx-font-size: 12px;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="← Retour à l'accueil" onAction="#onBackHome" style="-fx-background-color: transparent; -fx-text-fill: #7c3aed; -fx-font-size: 13px; -fx-cursor: hand;"/>
            </HBox>
        </VBox>
    </ScrollPane>

    <!-- 2. LE CHATBOT (FIXÉ PAR DESSUS TOUT) -->
    <VBox fx:id="chatContainer" visible="false" managed="false" 
          StackPane.alignment="BOTTOM_RIGHT" maxWidth="350" maxHeight="500"
          style="-fx-background-color: #110f28; -fx-border-color: #a855f7; -fx-border-width: 2; -fx-border-radius: 15; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(168,85,247,0.4), 20, 0, 0, 5);">
        <StackPane.margin>
            <Insets bottom="100" right="30"/>
        </StackPane.margin>
        
        <HBox style="-fx-background-color: #a855f7; -fx-background-radius: 12 12 0 0; -fx-padding: 15;" alignment="CENTER_LEFT" spacing="10">
            <Label text="🤖" style="-fx-font-size: 18px;"/>
            <Label text="NexUS AI Assistant" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#toggleChat" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand;"/>
        </HBox>
        
        <TextArea fx:id="chatArea" editable="false" wrapText="true" VBox.vgrow="ALWAYS"
                  style="-fx-control-inner-background: #0d0b1e; -fx-text-fill: white; -fx-font-size: 13px;"/>
        
        <HBox style="-fx-padding: 12;" spacing="8">
            <TextField fx:id="chatInput" HBox.hgrow="ALWAYS" promptText="Posez votre question..." onAction="#onSendMessage"
                       style="-fx-background-color: #1a103d; -fx-text-fill: white; -fx-border-color: rgba(168,85,247,0.3); -fx-border-radius: 8;"/>
            <Button text="OK" onAction="#onSendMessage" style="-fx-background-color: #a855f7; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
        </HBox>
    </VBox>

    <Button text="💬 AI" onAction="#toggleChat" 
            StackPane.alignment="BOTTOM_RIGHT"
            style="-fx-background-color: linear-gradient(to bottom right, #a855f7, #ec4899);
                   -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px;
                   -fx-background-radius: 50; -fx-min-width: 65; -fx-min-height: 65;
                   -fx-effect: dropshadow(gaussian, rgba(168,85,247,0.6), 15, 0, 0, 5);">
        <StackPane.margin>
            <Insets bottom="30" right="30"/>
        </StackPane.margin>
    </Button>

</StackPane>

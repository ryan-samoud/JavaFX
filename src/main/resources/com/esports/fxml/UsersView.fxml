<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17"
      fx:controller="com.esports.controller.UsersController"
      styleClass="content-area">

    <stylesheets>
        <URL value="@../css/dashboard.css"/>
    </stylesheets>

    <!-- ── TOPBAR ─────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="topbar">
        <Label text="👥" style="-fx-font-size: 22px;"/>
        <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Gestion des Utilisateurs" styleClass="page-title"/>
            <Label fx:id="lblUserCount" text="Chargement…"
                   style="-fx-text-fill: #7c6fa8; -fx-font-size: 12px;"/>
        </VBox>

        <TextField fx:id="fieldSearch"
                   promptText="🔍  Rechercher un utilisateur…"
                   prefWidth="260" styleClass="input-field"/>

        <ComboBox fx:id="comboRoleFilter"
                  promptText="Tous les rôles"
                  prefWidth="150" styleClass="combo-filter"/>

        <ComboBox fx:id="comboStatusFilter"
                  promptText="Tous les statuts"
                  prefWidth="160" styleClass="combo-filter"/>

        <Button text="＋  Ajouter" onAction="#onAddUser" styleClass="btn-primary"/>
    </HBox>

    <!-- ── CONTENT (table + side form) ───────────────────── -->
    <HBox VBox.vgrow="ALWAYS" spacing="0"
          style="-fx-background-color: #0a0818;">

        <!-- TABLE -->
        <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 24 0 30 36;">
            <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS"
                       styleClass="esports-table">
                <columns>
                    <TableColumn fx:id="colId"        text="ID"         prefWidth="55"/>
                    <TableColumn fx:id="colNom"       text="NOM"        prefWidth="120"/>
                    <TableColumn fx:id="colPrenom"    text="PRÉNOM"     prefWidth="120"/>
                    <TableColumn fx:id="colEmail"     text="EMAIL"      prefWidth="195"/>
                    <TableColumn fx:id="colRole"      text="RÔLE"       prefWidth="110"/>
                    <TableColumn fx:id="colActive"    text="STATUT"     prefWidth="130"/>
                    <TableColumn fx:id="colCreatedAt" text="INSCRIT LE" prefWidth="110"/>
                    <TableColumn fx:id="colActions"   text="ACTIONS"    prefWidth="230"/>
                </columns>
                <placeholder>
                    <Label text="Aucun utilisateur trouvé."
                           styleClass="empty-label"/>
                </placeholder>
            </TableView>
        </VBox>

    </HBox>
</VBox>

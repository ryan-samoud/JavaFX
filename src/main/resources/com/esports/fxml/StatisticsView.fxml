<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:id="scrollRoot"
            fx:controller="com.esports.controller.StatisticsController"
            fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            style="-fx-background-color: #0a0818; -fx-border-color: transparent; -fx-background: #0a0818;">

    <stylesheets>
        <URL value="@../css/dashboard.css"/>
    </stylesheets>

    <VBox fx:id="boxRoot" spacing="24" style="-fx-padding: 24 32 40 32; -fx-background-color: #0a0818;">

        <!-- Topbar -->
        <HBox alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color: #0f0d22; -fx-padding: 16 22 16 22;
                     -fx-border-color: transparent transparent rgba(139,92,246,0.18) transparent;
                     -fx-border-width: 0 0 1 0; -fx-background-radius: 12;">
            <Label text="📈" style="-fx-font-size: 22px;"/>
            <VBox spacing="2">
                <Label text="Statistiques"
                       style="-fx-text-fill: #e2d9f3; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                <Label text="Jeux &amp; catégories — vue synthétique pour l’administrateur"
                       style="-fx-text-fill: #7c6fa8; -fx-font-size: 12px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <!-- KPI -->
        <HBox spacing="14">
            <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card" spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🎮" style="-fx-font-size: 18px;"/>
                    <Label text="TOTAL JEUX" styleClass="kpi-title"/>
                </HBox>
                <Label fx:id="lblKpiJeux" text="0" styleClass="kpi-value"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card" spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="📁" style="-fx-font-size: 18px;"/>
                    <Label text="CATÉGORIES" styleClass="kpi-title"/>
                </HBox>
                <Label fx:id="lblKpiCats" text="0" styleClass="kpi-value-blue"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card" spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="⭐" style="-fx-font-size: 18px;"/>
                    <Label text="NOTE MOYENNE" styleClass="kpi-title"/>
                </HBox>
                <Label fx:id="lblKpiNote" text="—" styleClass="kpi-value-orange"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card" spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="🕹" style="-fx-font-size: 18px;"/>
                    <Label text="MODES (SOLO / MULTI…)" styleClass="kpi-title"/>
                </HBox>
                <Label fx:id="lblKpiModes" text="—" styleClass="kpi-value-green" wrapText="true"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card" spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="👤" style="-fx-font-size: 18px;"/>
                    <Label text="UTILISATEURS ACTIFS" styleClass="kpi-title"/>
                </HBox>
                <Label fx:id="lblKpiUsers" text="0" styleClass="kpi-value-pink"/>
            </VBox>
            <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card" spacing="8">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="❤️" style="-fx-font-size: 18px;"/>
                    <Label text="RÉACTIONS" styleClass="kpi-title"/>
                </HBox>
                <Label fx:id="lblKpiReactions" text="0" styleClass="kpi-value"/>
            </VBox>
        </HBox>

        <!-- Pie -->
        <VBox spacing="10" style="-fx-background-color: #0f0d22; -fx-background-radius: 14;
                   -fx-border-color: rgba(139,92,246,0.2); -fx-border-width: 1.5; -fx-border-radius: 14;
                   -fx-padding: 16 20 20 20;">
            <Label text="Répartition des jeux par catégorie (camembert)"
                   style="-fx-text-fill: #e2d9f3; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Canvas fx:id="canvasPie" width="520" height="300"/>
        </VBox>

        <!-- Bar + Line -->
        <HBox spacing="18" alignment="TOP_CENTER">
            <VBox spacing="10" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #0f0d22; -fx-background-radius: 14;
                         -fx-border-color: rgba(139,92,246,0.2); -fx-border-width: 1.5; -fx-border-radius: 14;
                         -fx-padding: 16 16 18 16;">
                <Label text="Volume par catégorie (barres)"
                       style="-fx-text-fill: #e2d9f3; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Canvas fx:id="canvasBar" width="400" height="280"/>
            </VBox>
            <VBox spacing="10" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #0f0d22; -fx-background-radius: 14;
                         -fx-border-color: rgba(139,92,246,0.2); -fx-border-width: 1.5; -fx-border-radius: 14;
                         -fx-padding: 16 16 18 16;">
                <Label text="Note moyenne par catégorie (courbe)"
                       style="-fx-text-fill: #e2d9f3; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Canvas fx:id="canvasLine" width="400" height="280"/>
            </VBox>
        </HBox>

        <!-- Users + Reactions -->
        <HBox spacing="18" alignment="TOP_CENTER">
            <VBox spacing="10" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #0f0d22; -fx-background-radius: 14;
                         -fx-border-color: rgba(139,92,246,0.2); -fx-border-width: 1.5; -fx-border-radius: 14;
                         -fx-padding: 16 16 18 16;">
                <Label text="Utilisateurs par rôle (barres)"
                       style="-fx-text-fill: #e2d9f3; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Canvas fx:id="canvasUsers" width="400" height="260"/>
            </VBox>
            <VBox spacing="10" HBox.hgrow="ALWAYS"
                  style="-fx-background-color: #0f0d22; -fx-background-radius: 14;
                         -fx-border-color: rgba(139,92,246,0.2); -fx-border-width: 1.5; -fx-border-radius: 14;
                         -fx-padding: 16 16 18 16;">
                <Label text="Réactions par type (camembert)"
                       style="-fx-text-fill: #e2d9f3; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Canvas fx:id="canvasReactions" width="400" height="260"/>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>

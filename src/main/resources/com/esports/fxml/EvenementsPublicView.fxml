<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import java.net.URL?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.esports.controller.EvenementsPublicController"
            style="-fx-background: #0d0b1e; -fx-background-color: #0d0b1e; -fx-border-color: transparent;">

    <stylesheets>
        <URL value="@../css/home.css"/>
    </stylesheets>

    <VBox style="-fx-background-color: #0d0b1e;" spacing="0">

        <!-- ══════════════════════════════════════════ -->
        <!-- NAVBAR                                     -->
        <!-- ══════════════════════════════════════════ -->
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="N"
                       style="-fx-background-color: #a855f7; -fx-text-fill: white;
                              -fx-font-size: 15px; -fx-font-weight: bold;
                              -fx-background-radius: 6px; -fx-padding: 4 9 4 9;
                              -fx-effect: dropshadow(gaussian, rgba(168,85,247,0.8), 10, 0.4, 0, 0);"/>
                <Label text="NexUS"
                       style="-fx-text-fill: white; -fx-font-size: 18px;
                              -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Accueil" onAction="#onBackHome" styleClass="nav-link"/>
            <Button text="Jeux" styleClass="nav-link"/>
            <Button text="Tournois" styleClass="nav-link"/>
            <Button text="Boutique" styleClass="nav-link"/>
            <Button text="Événements"
                    style="-fx-background-color: rgba(168,85,247,0.12); -fx-text-fill: #c084fc;
                           -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;
                           -fx-border-color: transparent transparent #a855f7 transparent;
                           -fx-border-width: 0 0 2 0; -fx-padding: 7 14 5 14; -fx-background-radius: 6px;"/>
            <Button text="Connexion" onAction="#onBackHome" styleClass="btn-outline-sm"/>
        </HBox>

        <!-- ══════════════════════════════════════════ -->
        <!-- HERO + FILTRES                             -->
        <!-- ══════════════════════════════════════════ -->
        <VBox alignment="CENTER" spacing="12"
              style="-fx-background-color: linear-gradient(to bottom, #100c2a, #1a0a3e 50%, #0d0b1e);
                     -fx-padding: 60 40 60 40; -fx-min-height: 260px;">

            <HBox alignment="CENTER" spacing="10">
                <Rectangle width="4" height="36" arcWidth="2" arcHeight="2"
                           style="-fx-fill: linear-gradient(to bottom, #a855f7, #ec4899);"/>
                <Label text="ÉVÉNEMENTS"
                       style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold;
                              -fx-font-family: 'Arial Black';
                              -fx-effect: dropshadow(gaussian, rgba(168,85,247,0.6), 20, 0.3, 0, 0);"/>
            </HBox>

            <Label text="Découvrez et participez aux événements eSports NexUS"
                   style="-fx-text-fill: #c4b5fd; -fx-font-size: 15px; -fx-padding: 0 0 8 0;"/>

            <HBox alignment="CENTER" spacing="12">
                <TextField fx:id="fieldSearch" promptText="🔍  Rechercher…" prefWidth="260"
                           style="-fx-background-color: rgba(26,18,58,0.9); -fx-text-fill: white;
                                  -fx-prompt-text-fill: #6b7280;
                                  -fx-border-color: rgba(139,92,246,0.4); -fx-border-width: 1.5px;
                                  -fx-border-radius: 8px; -fx-background-radius: 8px;
                                  -fx-font-size: 14px; -fx-padding: 11 16 11 16;"/>

                <ComboBox fx:id="comboFilter"
                          style="-fx-background-color: rgba(26,18,58,0.9); -fx-text-fill: white;
                                 -fx-font-size: 13px; -fx-border-color: rgba(139,92,246,0.4);
                                 -fx-border-width: 1.5px; -fx-border-radius: 8px; -fx-background-radius: 8px;
                                 -fx-padding: 4 10 4 10;"/>

                <ComboBox fx:id="comboSort"
                          style="-fx-background-color: rgba(26,18,58,0.9); -fx-text-fill: white;
                                 -fx-font-size: 13px; -fx-border-color: rgba(139,92,246,0.4);
                                 -fx-border-width: 1.5px; -fx-border-radius: 8px; -fx-background-radius: 8px;
                                 -fx-padding: 4 10 4 10;"/>

                <Button text="Rechercher" onAction="#onSearch" styleClass="btn-hero-primary"/>
            </HBox>
        </VBox>

        <!-- ══════════════════════════════════════════ -->
        <!-- STATS BAR                                  -->
        <!-- ══════════════════════════════════════════ -->
        <HBox alignment="CENTER" spacing="0"
              style="-fx-background-color: #110f28;
                     -fx-border-color: transparent transparent rgba(139,92,246,0.15) transparent;
                     -fx-border-width: 0 0 1 0; -fx-padding: 18 40 18 40;">

            <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="lblTotalCount" text="—"
                       style="-fx-text-fill: #a855f7; -fx-font-size: 26px; -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
                <Label text="Total" style="-fx-text-fill: #9ca3af; -fx-font-size: 12px;"/>
            </VBox>
            <Rectangle width="1" height="36" style="-fx-fill: rgba(139,92,246,0.2);"/>
            <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="lblUpcomingCount" text="—"
                       style="-fx-text-fill: #4ade80; -fx-font-size: 26px; -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
                <Label text="À venir" style="-fx-text-fill: #9ca3af; -fx-font-size: 12px;"/>
            </VBox>
            <Rectangle width="1" height="36" style="-fx-fill: rgba(139,92,246,0.2);"/>
            <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="lblPassedCount" text="—"
                       style="-fx-text-fill: #6b7280; -fx-font-size: 26px; -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
                <Label text="Passés" style="-fx-text-fill: #9ca3af; -fx-font-size: 12px;"/>
            </VBox>
        </HBox>

        <!-- ══════════════════════════════════════════ -->
        <!-- MAIN CONTENT — Cards + Calendar sidebar    -->
        <!-- ══════════════════════════════════════════ -->
        <HBox spacing="28" style="-fx-background-color: #0d0b1e; -fx-padding: 40 40 60 40;">

            <!-- ── Cards section ── -->
            <VBox spacing="28" HBox.hgrow="ALWAYS">

                <Label fx:id="lblEmpty" text="Aucun événement disponible pour le moment."
                       visible="false" managed="false"
                       style="-fx-text-fill: #6b7280; -fx-font-size: 15px;"/>

                <!-- À venir -->
                <VBox spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Circle radius="5"
                                style="-fx-fill: #a855f7; -fx-effect: dropshadow(gaussian,rgba(168,85,247,0.8),8,0.4,0,0);"/>
                        <Label text="À VENIR"
                               style="-fx-text-fill: #a855f7; -fx-font-size: 13px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
                    </HBox>
                    <FlowPane fx:id="paneUpcoming" hgap="18" vgap="18" prefWrapLength="9999"/>
                </VBox>

                <!-- Passés -->
                <VBox spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Circle radius="5" style="-fx-fill: #4b5563;"/>
                        <Label text="PASSÉS"
                               style="-fx-text-fill: #4b5563; -fx-font-size: 13px; -fx-font-weight: bold; -fx-letter-spacing: 2px;"/>
                    </HBox>
                    <FlowPane fx:id="panePassed" hgap="18" vgap="18" prefWrapLength="9999"/>
                </VBox>
            </VBox>

            <!-- ── Calendar sidebar ── -->
            <VBox spacing="0" minWidth="240" maxWidth="240"
                  style="-fx-background-color: rgba(17,11,40,0.92);
                         -fx-border-color: rgba(139,92,246,0.25); -fx-border-width: 1.5px;
                         -fx-border-radius: 14px; -fx-background-radius: 14px;
                         -fx-padding: 0 0 18 0; -fx-min-height: 300px; -fx-max-height: 360px;">

                <!-- Calendar header -->
                <HBox alignment="CENTER" spacing="0"
                      style="-fx-background-color: linear-gradient(to right, #7c3aed, #ec4899);
                             -fx-background-radius: 13px 13px 0 0; -fx-padding: 12 10 12 10;">
                    <Button text="‹" onAction="#onPrevMonth"
                            style="-fx-background-color: transparent; -fx-text-fill: white;
                                   -fx-font-size: 16px; -fx-font-weight: bold;
                                   -fx-cursor: hand; -fx-border-color: transparent; -fx-padding: 0 10 0 10;"/>
                    <Label fx:id="lblCalendarMonth" text="—" HBox.hgrow="ALWAYS"
                           style="-fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold;
                                  -fx-font-family: 'Courier New'; -fx-letter-spacing: 1px;
                                  -fx-alignment: CENTER;" maxWidth="200"/>
                    <Button text="›" onAction="#onNextMonth"
                            style="-fx-background-color: transparent; -fx-text-fill: white;
                                   -fx-font-size: 16px; -fx-font-weight: bold;
                                   -fx-cursor: hand; -fx-border-color: transparent; -fx-padding: 0 10 0 10;"/>
                </HBox>

                <!-- Grid -->
                <GridPane fx:id="calendarGrid" hgap="4" vgap="4"
                          style="-fx-padding: 14 12 4 12;" alignment="CENTER"/>

                <!-- Legend -->
                <VBox spacing="6" style="-fx-padding: 12 14 0 14;">
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Region minWidth="12" minHeight="12" maxWidth="12" maxHeight="12"
                                style="-fx-background-color: #7c3aed; -fx-background-radius: 3px;"/>
                        <Label text="Aujourd'hui" style="-fx-text-fill: #9ca3af; -fx-font-size: 11px;"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Region minWidth="12" minHeight="12" maxWidth="12" maxHeight="12"
                                style="-fx-background-color: rgba(168,85,247,0.2); -fx-background-radius: 3px;"/>
                        <Label text="Événement" style="-fx-text-fill: #9ca3af; -fx-font-size: 11px;"/>
                    </HBox>
                </VBox>
            </VBox>

        </HBox>

        <!-- ══════════════════════════════════════════ -->
        <!-- FOOTER                                     -->
        <!-- ══════════════════════════════════════════ -->
        <HBox alignment="CENTER" spacing="20"
              style="-fx-background-color: #080714;
                     -fx-border-color: rgba(139,92,246,0.15) transparent transparent transparent;
                     -fx-border-width: 1 0 0 0; -fx-padding: 24 40 24 40;">
            <Label text="N" style="-fx-background-color: #a855f7; -fx-text-fill: white;
                                    -fx-font-size: 13px; -fx-font-weight: bold;
                                    -fx-background-radius: 5px; -fx-padding: 3 8 3 8;"/>
            <Label text="NexUS Gaming Arena — Tous droits réservés"
                   style="-fx-text-fill: #4b5563; -fx-font-size: 12px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Retour à l'accueil" onAction="#onBackHome"
                    style="-fx-background-color: transparent; -fx-text-fill: #7c3aed;
                           -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: transparent;"/>
        </HBox>

    </VBox>
</ScrollPane>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<ScrollPane fitToWidth="true" fitToHeight="true"
            hbarPolicy="NEVER" vbarPolicy="NEVER"
            minWidth="1280" minHeight="800"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.esports.controller.ForgotPasswordController"
            styleClass="home-scroll">

    <stylesheets>
        <URL value="@../css/home.css"/>
        <URL value="@../css/register.css"/>
    </stylesheets>

    <VBox styleClass="home-root" spacing="0" minWidth="1280" minHeight="800">

        <!-- NAVBAR -->
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="N" style="-fx-background-color: #a855f7; -fx-text-fill: white;
                       -fx-font-size: 15px; -fx-font-weight: bold;
                       -fx-background-radius: 6px; -fx-padding: 4 9 4 9;
                       -fx-effect: dropshadow(gaussian, rgba(168,85,247,0.8), 10, 0.4, 0, 0);"/>
                <Label text="NexUS" style="-fx-text-fill: white; -fx-font-size: 18px;
                       -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnBack" text="← Retour" onAction="#onBack" styleClass="btn-outline-sm"/>
        </HBox>

        <!-- CONTENT -->
        <VBox alignment="CENTER" spacing="0" VBox.vgrow="ALWAYS"
              style="-fx-background-color: linear-gradient(to bottom, #100c2a, #1a0a3e 45%, #0d0b1e);
                     -fx-padding: 60 40 60 40;">

            <!-- ══════════════ STEP 1 : enter email ══════════════ -->
            <VBox fx:id="step1Panel" alignment="CENTER" spacing="20" maxWidth="400">

                <Label text="MOT DE PASSE OUBLIÉ" styleClass="section-title-center"/>
                <Label text="Entrez votre adresse e-mail pour recevoir un code de vérification"
                       styleClass="section-subtitle-center" wrapText="true"
                       style="-fx-text-alignment: center;"/>

                <VBox spacing="14" maxWidth="380">
                    <VBox spacing="4">
                        <Label text="Adresse e-mail" styleClass="field-label"/>
                        <TextField fx:id="fieldEmail"
                                   promptText="exemple@email.com"
                                   styleClass="input-field"/>
                    </VBox>

                    <Label fx:id="lblStep1Error" styleClass="error-label" wrapText="true"/>
                    <Label fx:id="lblStep1Info"
                           style="-fx-text-fill: #a855f7; -fx-font-size: 13px;"
                           wrapText="true"/>

                    <Button fx:id="btnSend"
                            text="ENVOYER LE CODE"
                            onAction="#onSendCode"
                            styleClass="btn-neon"
                            maxWidth="Infinity"/>

                    <Button text="Retour à la connexion"
                            onAction="#onBack"
                            styleClass="btn-hero-ghost"
                            maxWidth="Infinity"/>
                </VBox>
            </VBox>

            <!-- ══════════════ STEP 2 : enter code ══════════════ -->
            <VBox fx:id="step2Panel" alignment="CENTER" spacing="20" maxWidth="400"
                  visible="false" managed="false">

                <Label text="VÉRIFICATION" styleClass="section-title-center"/>
                <Label fx:id="lblCodeSentTo"
                       text="Un code à 6 chiffres a été envoyé à votre adresse e-mail."
                       styleClass="section-subtitle-center" wrapText="true"
                       style="-fx-text-alignment: center;"/>

                <VBox spacing="14" maxWidth="380">
                    <VBox spacing="4">
                        <Label text="Code de vérification" styleClass="field-label"/>
                        <TextField fx:id="fieldCode"
                                   promptText="000000"
                                   styleClass="input-field"
                                   style="-fx-font-size: 24px; -fx-letter-spacing: 6px;
                                          -fx-text-alignment: center;"/>
                    </VBox>

                    <Label fx:id="lblStep2Error" styleClass="error-label" wrapText="true"/>

                    <Button fx:id="btnVerify"
                            text="VÉRIFIER LE CODE"
                            onAction="#onVerifyCode"
                            styleClass="btn-neon"
                            maxWidth="Infinity"/>

                    <Button text="Renvoyer un code"
                            onAction="#onResendCode"
                            styleClass="btn-hero-ghost"
                            maxWidth="Infinity"/>
                </VBox>
            </VBox>

        </VBox>
    </VBox>
</ScrollPane>
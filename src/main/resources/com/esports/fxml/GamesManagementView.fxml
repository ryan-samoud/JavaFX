<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import java.net.URL?>

<VBox xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17"
      fx:controller="com.esports.controller.GamesManagementController"
      style="-fx-background-color: #0a0818;" prefWidth="1200" prefHeight="850">

    <stylesheets>
        <URL value="@../css/dashboard.css"/>
    </stylesheets>

    <!-- TOPBAR -->
    <HBox alignment="CENTER_LEFT" spacing="14"
          style="-fx-background-color: #0f0d22; -fx-padding: 16 30; -fx-border-color: transparent transparent rgba(139,92,246,0.18) transparent; -fx-border-width: 0 0 1 0;">
        <Label text="🎮" style="-fx-font-size: 24;"/>
        <Label text="Administration des Jeux &amp; Catégories" style="-fx-text-fill: #e2d9f3; -fx-font-size: 26; -fx-font-weight: bold;"/>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="35" style="-fx-padding: 30;">

            <!-- ================= SECTION 1: CATÉGORIES ================= -->
            <VBox spacing="15" styleClass="card-bg" style="-fx-padding: 25; -fx-background-color: #14112b; -fx-background-radius: 18; -fx-border-color: rgba(139,92,246,0.15); -fx-border-width: 1;">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="📂" style="-fx-font-size: 24;"/>
                    <VBox>
                        <Label text="Gestion des Catégories" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 20;"/>
                        <Label text="Organisez vos titres par genre ou plateforme" style="-fx-text-fill: #9ca3af; -fx-font-size: 13;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="fieldSearchCat" promptText="🔍 Rechercher une catégorie..." styleClass="modern-field" prefWidth="300" prefHeight="40"/>
                    <Button text="+ Ajouter Catégorie" onAction="#onOpenAddCat" styleClass="btn-primary" prefHeight="40" style="-fx-padding: 0 25;"/>
                </HBox>

                <TableView fx:id="tableCats" prefHeight="250" styleClass="modern-table">
                    <columns>
                        <TableColumn fx:id="colCatId" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="colCatNom" text="Nom de la Catégorie" prefWidth="350"/>
                        <TableColumn fx:id="colCatGenre" text="Genre / Icône" prefWidth="250"/>
                        <TableColumn fx:id="colCatActions" text="Actions" prefWidth="200"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- ================= SECTION 2: JEUX ================= -->
            <VBox spacing="15" styleClass="card-bg" style="-fx-padding: 25; -fx-background-color: #14112b; -fx-background-radius: 18; -fx-border-color: rgba(139,92,246,0.15); -fx-border-width: 1;">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="🎮" style="-fx-font-size: 24;"/>
                    <VBox>
                        <Label text="Bibliothèque des Jeux" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 20;"/>
                        <Label text="Gérez les détails, les images et les notes des jeux" style="-fx-text-fill: #9ca3af; -fx-font-size: 13;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="fieldSearchGame" promptText="🔍 Rechercher un jeu..." styleClass="modern-field" prefWidth="300" prefHeight="40"/>
                    <Button text="+ Nouveau Jeu" onAction="#onOpenAddGame" styleClass="btn-primary" prefHeight="40" style="-fx-padding: 0 25;"/>
                </HBox>

                <TableView fx:id="tableGames" prefHeight="450" styleClass="modern-table">
                    <columns>
                        <TableColumn fx:id="colGameImage" text="Image" prefWidth="100"/>
                        <TableColumn fx:id="colGameNom" text="Titre du Jeu" prefWidth="220"/>
                        <TableColumn fx:id="colGameCat" text="Catégorie" prefWidth="150"/>
                        <TableColumn fx:id="colGameMode" text="Mode" prefWidth="100"/>
                        <TableColumn fx:id="colGameAge" text="Âge" prefWidth="60"/>
                        <TableColumn fx:id="colGameNote" text="Note" prefWidth="70"/>
                        <TableColumn fx:id="colGamePlayers" text="Joueurs" prefWidth="80"/>
                        <TableColumn fx:id="colGameActions" text="Actions" prefWidth="200"/>
                    </columns>
                </TableView>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>

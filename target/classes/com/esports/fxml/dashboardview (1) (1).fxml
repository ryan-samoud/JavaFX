<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.*?>
<?import java.net.URL?>

<!-- Contenu seul — la sidebar est dans MainView.fxml -->
<VBox xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17"
      fx:controller="com.esports.controller.DashboardController"
      style="-fx-background-color: #0a0818;">

    <stylesheets>
        <URL value="@../css/dashboard.css"/>
    </stylesheets>

    <!-- TOPBAR -->
    <HBox alignment="CENTER_LEFT" spacing="14"
          style="-fx-background-color: #0f0d22; -fx-padding: 16 30 16 30;
                 -fx-border-color: transparent transparent rgba(139,92,246,0.18) transparent;
                 -fx-border-width: 0 0 1 0; -fx-min-height: 64px;">

        <Label text="📊" style="-fx-font-size: 20px;"/>
        <Label text="Dashboard"
               style="-fx-text-fill: #e2d9f3; -fx-font-size: 24px; -fx-font-weight: bold;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Button text="🔔"
                style="-fx-background-color: rgba(168,85,247,0.12);
                       -fx-text-fill: #a855f7; -fx-font-size: 15px;
                       -fx-background-radius: 8; -fx-border-color: transparent;
                       -fx-padding: 8 13 8 13; -fx-cursor: hand;"/>
    </HBox>

    <!-- SCROLLABLE CONTENT -->
    <ScrollPane fitToWidth="true"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                VBox.vgrow="ALWAYS"
                style="-fx-background-color: #0a0818; -fx-border-color: transparent;
                       -fx-background: #0a0818;">

        <VBox spacing="28"
              style="-fx-padding: 30 36 40 36; -fx-background-color: #0a0818;">

            <!-- ===== KPI CARDS ===== -->
            <HBox spacing="16">

                <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card" spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="👥" style="-fx-font-size: 20px;"/>
                        <Label text="UTILISATEURS" styleClass="kpi-title"/>
                    </HBox>
                    <Label fx:id="lblTotalUsers" text="—" styleClass="kpi-value"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card" spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="🏆" style="-fx-font-size: 20px;"/>
                        <Label text="TOURNOIS" styleClass="kpi-title"/>
                    </HBox>
                    <Label fx:id="lblTotalTournaments" text="—" styleClass="kpi-value-blue"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card" spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="⚡" style="-fx-font-size: 20px;"/>
                        <Label text="ÉQUIPES" styleClass="kpi-title"/>
                    </HBox>
                    <Label fx:id="lblTotalTeams" text="—" styleClass="kpi-value-orange"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS" styleClass="kpi-card" spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="🛒" style="-fx-font-size: 20px;"/>
                        <Label text="BOUTIQUE" styleClass="kpi-title"/>
                    </HBox>
                    <Label fx:id="lblTotalProducts" text="—" styleClass="kpi-value-green"/>
                </VBox>

            </HBox>

            <!-- ===== RECENT USERS TABLE ===== -->
            <VBox spacing="0"
                  style="-fx-background-color: #14112b;
                         -fx-border-color: rgba(139,92,246,0.2);
                         -fx-border-width: 1.5; -fx-border-radius: 14;
                         -fx-background-radius: 14;">

                <!-- Card header -->
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding: 18 24 14 24;
                             -fx-border-color: transparent transparent rgba(139,92,246,0.15) transparent;
                             -fx-border-width: 0 0 1 0;">
                    <Label text="👥" style="-fx-font-size: 16px; -fx-text-fill: #a855f7;"/>
                    <Label text="Utilisateurs Récents"
                           style="-fx-text-fill: #e2d9f3; -fx-font-size: 16px; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="+ Nouvel utilisateur"
                            onAction="#onNewUser"
                            style="-fx-background-color: linear-gradient(to right, #7c3aed, #ec4899);
                                   -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 12px;
                                   -fx-padding: 8 16 8 16; -fx-background-radius: 8;
                                   -fx-border-color: transparent; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(168,85,247,0.4), 10, 0.3, 0, 2);"/>
                </HBox>

                <!-- Column headers -->
                <HBox style="-fx-padding: 10 24 10 24;
                             -fx-border-color: transparent transparent rgba(139,92,246,0.1) transparent;
                             -fx-border-width: 0 0 1 0;" spacing="0">
                    <Label text="NOM"
                           style="-fx-text-fill: #7c6fa8; -fx-font-size: 11px;
                                  -fx-font-weight: bold; -fx-pref-width: 220px;"/>
                    <Label text="EMAIL"
                           style="-fx-text-fill: #7c6fa8; -fx-font-size: 11px;
                                  -fx-font-weight: bold; -fx-pref-width: 280px;"/>
                    <Label text="RÔLE"
                           style="-fx-text-fill: #7c6fa8; -fx-font-size: 11px;
                                  -fx-font-weight: bold;"/>
                </HBox>

                <!-- Rows injectées par le controller -->
                <VBox fx:id="recentUsersContainer" spacing="0"
                      style="-fx-padding: 0 0 8 0;"/>

            </VBox>

        </VBox>
    </ScrollPane>

</VBox>

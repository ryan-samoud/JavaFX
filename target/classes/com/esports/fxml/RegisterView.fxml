<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<ScrollPane fitToWidth="true" fitToHeight="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            minWidth="1280" minHeight="800"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.esports.controller.RegisterController"
            styleClass="home-scroll">

    <stylesheets>
        <URL value="@../css/home.css"/>
        <URL value="@../css/register.css"/>
    </stylesheets>

    <VBox styleClass="home-root" spacing="0" minWidth="1280" minHeight="800">

        <!-- NAVBAR -->
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="N" style="-fx-background-color: #a855f7; -fx-text-fill: white;
                       -fx-font-size: 15px; -fx-font-weight: bold;
                       -fx-background-radius: 6px; -fx-padding: 4 9 4 9;
                       -fx-effect: dropshadow(gaussian, rgba(168,85,247,0.8), 10, 0.4, 0, 0);"/>
                <Label text="NexUS" style="-fx-text-fill: white; -fx-font-size: 18px;
                       -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Déjà un compte ?" onAction="#onGoLogin" styleClass="btn-outline-sm"/>
        </HBox>

        <!-- REGISTER FORM -->
        <VBox styleClass="login-section" alignment="CENTER" spacing="18" VBox.vgrow="ALWAYS">

            <Label text="CRÉER UN COMPTE" styleClass="section-title-center"/>
            <Label text="Rejoignez NexUS Gaming Arena" styleClass="section-subtitle-center"/>

            <VBox spacing="12" maxWidth="420">

                <!-- NOM + PRENOM -->
                <HBox spacing="10">
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Nom" styleClass="field-label"/>
                        <TextField fx:id="fieldNom" promptText="Votre nom" styleClass="input-field"/>
                        <Label fx:id="errNom" styleClass="error-label"/>
                    </VBox>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Prénom" styleClass="field-label"/>
                        <TextField fx:id="fieldPrenom" promptText="Votre prénom" styleClass="input-field"/>
                        <Label fx:id="errPrenom" styleClass="error-label"/>
                    </VBox>
                </HBox>

                <!-- EMAIL -->
                <VBox spacing="4">
                    <Label text="Email" styleClass="field-label"/>
                    <TextField fx:id="fieldEmail" promptText="exemple@email.com" styleClass="input-field"/>
                    <Label fx:id="errEmail" styleClass="error-label"/>
                </VBox>

                <!-- AGE -->
                <VBox spacing="4">
                    <Label text="Âge" styleClass="field-label"/>
                    <TextField fx:id="fieldAge" promptText="Votre âge" styleClass="input-field"/>
                    <Label fx:id="errAge" styleClass="error-label"/>
                </VBox>

                <!-- ROLE -->
                <VBox spacing="8">
                    <Label text="Type de compte" styleClass="field-label"/>
                    <HBox spacing="20" alignment="CENTER_LEFT">
                        <RadioButton fx:id="rbJoueur" text="🎮  Joueur"
                                     selected="true"
                                     styleClass="radio-role"/>
                        <RadioButton fx:id="rbSpectateur" text="👁  Spectateur"
                                     styleClass="radio-role"/>
                    </HBox>
                    <Label fx:id="errRole" styleClass="error-label"/>
                </VBox>

                <!-- PASSWORD -->
                <VBox spacing="4">
                    <Label text="Mot de passe" styleClass="field-label"/>
                    <PasswordField fx:id="fieldPassword" promptText="Min. 8 caractères" styleClass="input-field"/>
                    <Label fx:id="errPassword" styleClass="error-label"/>
                </VBox>

                <!-- CONFIRM PASSWORD -->
                <VBox spacing="4">
                    <Label text="Confirmer le mot de passe" styleClass="field-label"/>
                    <PasswordField fx:id="fieldConfirm" promptText="Répétez le mot de passe" styleClass="input-field"/>
                    <Label fx:id="errConfirm" styleClass="error-label"/>
                </VBox>

                <!-- GLOBAL MESSAGE -->
                <Label fx:id="lblSuccess" styleClass="hero-stat-value" wrapText="true"/>
                <Label fx:id="lblError"   styleClass="error-label"     wrapText="true"/>

                <!-- SUBMIT -->
                <Button fx:id="btnRegister"
                        text="S'INSCRIRE"
                        onAction="#onRegister"
                        styleClass="btn-neon"
                        maxWidth="Infinity"/>

                <Button text="← Retour à l'accueil"
                        onAction="#onGoLogin"
                        styleClass="btn-hero-ghost"
                        maxWidth="Infinity"/>

            </VBox>
        </VBox>

    </VBox>
</ScrollPane>
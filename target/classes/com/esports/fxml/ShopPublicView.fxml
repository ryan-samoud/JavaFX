<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import java.net.URL?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.esports.controller.ShopPublicController"
            style="-fx-background-color: #0d0b1e;">

    <stylesheets>
        <URL value="@../css/home.css"/>
    </stylesheets>

    <!-- NAVBAR FIXE EN HAUT -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="N"
                       style="-fx-background-color: #a855f7; -fx-text-fill: white;
                              -fx-font-size: 15px; -fx-font-weight: bold;
                              -fx-background-radius: 6px; -fx-padding: 4 9 4 9;
                              -fx-effect: dropshadow(gaussian, rgba(168,85,247,0.8), 10, 0.4, 0, 0);"/>
                <Label text="NexUS"
                       style="-fx-text-fill: white; -fx-font-size: 18px;
                              -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="Accueil"    onAction="#onBackHome" styleClass="nav-link"/>
            <Button text="Jeux"       styleClass="nav-link"/>
            <Button text="Tournois"   styleClass="nav-link"/>
            <Button text="Boutique"
                    style="-fx-background-color: rgba(168,85,247,0.12);
                           -fx-text-fill: #c084fc; -fx-font-size: 14px; -fx-font-weight: bold;
                           -fx-cursor: hand;
                           -fx-border-color: transparent transparent #a855f7 transparent;
                           -fx-border-width: 0 0 2 0;
                           -fx-padding: 7 14 5 14; -fx-background-radius: 6px;"/>
            <Button text="Événements" styleClass="nav-link"/>

            <!-- Icône Trophée -->
            <Label text="🏆" style="-fx-font-size: 18px; -fx-cursor: hand;"/>

            <!-- Icône Panier avec badge -->
            <StackPane onMouseClicked="#onOpenPanier" style="-fx-cursor: hand;">
                <Label text="🛒" style="-fx-font-size: 18px;"/>
                <Label fx:id="lblPanierCount" text=""
                       visible="false" managed="false"
                       style="-fx-background-color: #ec4899; -fx-text-fill: white;
                              -fx-font-size: 9px; -fx-font-weight: bold;
                              -fx-background-radius: 10px; -fx-padding: 1 4 1 4;"
                       StackPane.alignment="TOP_RIGHT"/>
            </StackPane>

            <!-- Nom utilisateur connecté -->
            <Label fx:id="lblConnectedUser" text=""
                   style="-fx-text-fill: #4ade80; -fx-font-size: 13px; -fx-font-weight: bold;"
                   visible="false" managed="false"/>

            <!-- Bouton Déconnexion -->
            <Button fx:id="btnDeconnexion"
                    text="Déconnexion"
                    onAction="#onLogout"
                    visible="false" managed="false"
                    style="-fx-background-color: rgba(248,113,113,0.15);
                           -fx-text-fill: #f87171;
                           -fx-border-color: rgba(248,113,113,0.5);
                           -fx-border-width: 1.5px;
                           -fx-border-radius: 8px;
                           -fx-background-radius: 8px;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-padding: 7 20 7 20;
                           -fx-cursor: hand;"/>

            <!-- Connexion + S'inscrire -->
            <Button fx:id="btnConnexion" text="Connexion" onAction="#onLogin" styleClass="btn-outline-sm"/>

            <Button fx:id="btnInscrire" text="S'inscrire"
                    onAction="#onRegister"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: white;
                           -fx-border-color: rgba(255,255,255,0.5);
                           -fx-border-width: 1.5px;
                           -fx-border-radius: 8px;
                           -fx-background-radius: 8px;
                           -fx-font-size: 13px;
                           -fx-font-weight: bold;
                           -fx-padding: 7 20 7 20;
                           -fx-cursor: hand;"/>

            <!-- Bouton Admin -->
            <Button fx:id="btnAdmin"
                    text="⚙"
                    visible="false"
                    managed="false"
                    onAction="#onAdminBackoffice"
                    styleClass="btn-neon-sm"/>
        </HBox>
    </top>

    <!-- CONTENU SCROLLABLE -->
    <center>
        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED"
                    style="-fx-background: #0d0b1e; -fx-background-color: #0d0b1e; -fx-border-color: transparent;">

            <VBox style="-fx-background-color: #0d0b1e;" spacing="0">

                <!-- HERO HEADER -->
                <VBox alignment="CENTER" spacing="10"
                      style="-fx-background-color: linear-gradient(to bottom, #100c2a, #1a0a3e 50%, #0d0b1e);
                             -fx-padding: 50 40 50 40; -fx-min-height: 160px;">
                    <HBox alignment="CENTER" spacing="10">
                        <Rectangle width="4" height="32" arcWidth="2" arcHeight="2"
                                   style="-fx-fill: linear-gradient(to bottom, #a855f7, #ec4899);"/>
                        <Label text="BOUTIQUE"
                               style="-fx-text-fill: white; -fx-font-size: 36px;
                                      -fx-font-weight: bold; -fx-font-family: 'Arial Black';
                                      -fx-effect: dropshadow(gaussian, rgba(168,85,247,0.6), 20, 0.3, 0, 0);"/>
                    </HBox>
                    <Label text="Équipez-vous avec le meilleur équipement gaming"
                           style="-fx-text-fill: #c4b5fd; -fx-font-size: 15px;"/>
                </VBox>

                <!-- FILTRES CATÉGORIES + TRI + RECHERCHE IMAGE -->
                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color: #110f28;
             -fx-padding: 20 60 20 60;
             -fx-border-color: transparent transparent rgba(139,92,246,0.15) transparent;
             -fx-border-width: 0 0 1 0;">

                    <!-- Pills catégories -->
                    <HBox fx:id="boxCategories" spacing="12" alignment="CENTER_LEFT"
                          HBox.hgrow="ALWAYS"/>

                    <!-- Bouton recherche par image -->
                    <Button text="🔍 Par image" onAction="#onRechercherParImage"
                            style="-fx-background-color: rgba(139,92,246,0.2);
                   -fx-text-fill: #c4b5fd; -fx-font-size: 13px; -fx-font-weight: bold;
                   -fx-border-color: rgba(139,92,246,0.5); -fx-border-width: 1.5px;
                   -fx-border-radius: 8px; -fx-background-radius: 8px;
                   -fx-padding: 7 16 7 16; -fx-cursor: hand;"/>

                    <!-- Bouton réinitialiser -->
                    <Button text="↺ Tous" onAction="#onResetRecherche"
                            style="-fx-background-color: transparent;
                   -fx-text-fill: #9ca3af; -fx-font-size: 13px;
                   -fx-border-color: rgba(139,92,246,0.3); -fx-border-width: 1px;
                   -fx-border-radius: 8px; -fx-background-radius: 8px;
                   -fx-padding: 7 12 7 12; -fx-cursor: hand;"/>

                    <!-- Tri -->
                    <HBox alignment="CENTER_RIGHT" spacing="12">
                        <Label text="Trier par:"
                               style="-fx-text-fill: #9ca3af; -fx-font-size: 13px;"/>
                        <ComboBox fx:id="comboTri" prefWidth="180"
                                  style="-fx-background-color: rgba(26,18,58,0.9);
                         -fx-text-fill: white; -fx-font-size: 13px;
                         -fx-border-color: rgba(139,92,246,0.35); -fx-border-width: 1.5px;
                         -fx-border-radius: 8px; -fx-background-radius: 8px;
                         -fx-padding: 4 10 4 10;"/>
                    </HBox>
                </HBox>

                <!-- Loading bar -->
                <HBox fx:id="hboxLoading" alignment="CENTER" spacing="10"
                      visible="false" managed="false"
                      style="-fx-background-color: rgba(139,92,246,0.1);
             -fx-padding: 12 60 12 60;">
                    <Label text="🔍" style="-fx-font-size: 16px;"/>
                    <Label text="Analyse de l'image en cours avec Google Vision..."
                           style="-fx-text-fill: #c4b5fd; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                </HBox>

                <!-- GRILLE PRODUITS -->
                <VBox style="-fx-background-color: #0d0b1e; -fx-padding: 40 60 60 60;">

                    <Label fx:id="lblEmpty"
                           text="Aucun produit disponible pour le moment."
                           visible="false" managed="false"
                           style="-fx-text-fill: #6b7280; -fx-font-size: 15px; -fx-alignment: CENTER;"/>

                    <FlowPane fx:id="flowProduits"
                              hgap="24" vgap="24"
                              prefWrapLength="9999"
                              style="-fx-background-color: transparent;"/>
                </VBox>

                <!-- FOOTER -->
                <HBox alignment="CENTER" spacing="20"
                      style="-fx-background-color: #080714;
                             -fx-border-color: rgba(139,92,246,0.15) transparent transparent transparent;
                             -fx-border-width: 1 0 0 0; -fx-padding: 24 40 24 40;">
                    <Label text="N"
                           style="-fx-background-color: #a855f7; -fx-text-fill: white;
                                  -fx-font-size: 13px; -fx-font-weight: bold;
                                  -fx-background-radius: 5px; -fx-padding: 3 8 3 8;"/>
                    <Label text="NexUS Gaming Arena — Boutique"
                           style="-fx-text-fill: #4b5563; -fx-font-size: 12px;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="← Retour à l'accueil" onAction="#onBackHome"
                            style="-fx-background-color: transparent; -fx-text-fill: #7c3aed;
                                   -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: transparent;"/>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
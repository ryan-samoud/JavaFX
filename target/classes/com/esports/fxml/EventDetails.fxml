<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import java.net.URL?>
<VBox spacing="15" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.esports.controller.EventDetailsController"
      style="-fx-background-color: #0d0b1e; -fx-padding: 30;">

    <Label fx:id="lblNom"
           style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>

    <ImageView fx:id="imageView" fitWidth="300" preserveRatio="true"/>

    <Label fx:id="lblLieu" style="-fx-text-fill: #c084fc;"/>
    <Label fx:id="lblDate" style="-fx-text-fill: #9ca3af;"/>

    <Label fx:id="lblDesc"
           wrapText="true"
           maxWidth="320"
           style="-fx-text-fill: #d1d5db;"/>

    <Label fx:id="lblParticipants"
           style="-fx-text-fill: #4ade80; -fx-font-weight: bold;"/>

    <Button text="Fermer" onAction="#onClose"
            style="-fx-background-color: #a855f7; -fx-text-fill: white;"/>

</VBox>
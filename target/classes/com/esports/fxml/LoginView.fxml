<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.net.URL?>

<ScrollPane fitToWidth="true" fitToHeight="true"
            hbarPolicy="NEVER" vbarPolicy="NEVER"
            minWidth="1280" minHeight="800"
            xmlns:fx="http://javafx.com/fxml/1"
            xmlns="http://javafx.com/javafx/17"
            fx:controller="com.esports.controller.LoginController"
            styleClass="home-scroll">

    <stylesheets>
        <URL value="@../css/home.css"/>
        <URL value="@../css/register.css"/>
    </stylesheets>

    <VBox styleClass="home-root" spacing="0" minWidth="1280" minHeight="800">

        <!-- NAVBAR -->
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="20">
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="N" style="-fx-background-color: #a855f7; -fx-text-fill: white;
                       -fx-font-size: 15px; -fx-font-weight: bold;
                       -fx-background-radius: 6px; -fx-padding: 4 9 4 9;
                       -fx-effect: dropshadow(gaussian, rgba(168,85,247,0.8), 10, 0.4, 0, 0);"/>
                <Label text="NexUS" style="-fx-text-fill: white; -fx-font-size: 18px;
                       -fx-font-weight: bold; -fx-font-family: 'Arial Black';"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Retour" onAction="#onBack" styleClass="btn-outline-sm"/>
        </HBox>

        <!-- LOGIN FORM -->
        <VBox alignment="CENTER" spacing="20" VBox.vgrow="ALWAYS"
              style="-fx-background-color: linear-gradient(to bottom, #100c2a, #1a0a3e 45%, #0d0b1e);
                     -fx-padding: 60 40 60 40;">

            <Label text="CONNEXION" styleClass="section-title-center"/>
            <Label text="Accédez à votre espace NexUS" styleClass="section-subtitle-center"/>

            <VBox spacing="14" maxWidth="380">

                <VBox spacing="4">
                    <Label text="Email" styleClass="field-label"/>
                    <TextField fx:id="fieldEmail" promptText="exemple@email.com" styleClass="input-field"/>
                </VBox>

                <VBox spacing="4">
                    <Label text="Mot de passe" styleClass="field-label"/>
                    <PasswordField fx:id="fieldPassword" promptText="Mot de passe" styleClass="input-field"/>
                </VBox>

                <Label fx:id="lblError" styleClass="error-label" wrapText="true"/>
                <Label fx:id="lblSuccess" styleClass="hero-stat-value" wrapText="true"/>

                <Button fx:id="btnLogin"
                        text="SE CONNECTER"
                        onAction="#onLogin"
                        styleClass="btn-neon"
                        maxWidth="Infinity"/>

                <Button text="Pas encore de compte ? S'inscrire"
                        onAction="#onGoRegister"
                        styleClass="btn-hero-ghost"
                        maxWidth="Infinity"/>

            </VBox>
        </VBox>

    </VBox>
</ScrollPane>
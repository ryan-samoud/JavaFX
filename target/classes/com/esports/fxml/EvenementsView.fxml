<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>

<!--
    EvenementsView.fxml — Gestion des événements (back-office)
    Contrôleur : com.esports.controller.EvenementsController
-->

<VBox spacing="0"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17"
      fx:controller="com.esports.controller.EvenementsController"
      style="-fx-background-color: #0a0a0f;">

    <!-- Top bar -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-padding: 28 40 20 40;
                 -fx-border-color: transparent transparent #1a1a2e transparent;
                 -fx-border-width: 0 0 1 0;">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Rectangle width="4" height="26" arcWidth="2" arcHeight="2"
                           style="-fx-fill: #a855f7;"/>
                <Label text="ÉVÉNEMENTS"
                       style="-fx-text-fill: #ffffff;
                              -fx-font-family: 'Courier New';
                              -fx-font-size: 24px;
                              -fx-font-weight: bold;
                              -fx-letter-spacing: 3px;"/>
            </HBox>
            <Label fx:id="lblEventCount" text="Chargement…"
                   style="-fx-text-fill: #444455; -fx-font-family: 'Courier New'; -fx-font-size: 12px; -fx-padding: 0 0 0 14;"/>
        </VBox>

        <TextField fx:id="fieldSearch" promptText="🔍  Rechercher…"
                   prefWidth="220"
                   style="-fx-background-color: #111122; -fx-text-fill: #ffffff;
                          -fx-prompt-text-fill: #333344; -fx-font-family: 'Courier New';
                          -fx-font-size: 13px; -fx-border-color: #1a1a2e; -fx-border-width: 1;
                          -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 10 14 10 14;"/>

        <ComboBox fx:id="comboSort" promptText="Trier par"
                  style="-fx-background-color: #111122; -fx-text-fill: #ffffff;
                         -fx-font-family: 'Courier New'; -fx-font-size: 13px;
                         -fx-border-color: #1a1a2e; -fx-border-width: 1;
                         -fx-border-radius: 6; -fx-background-radius: 6; -fx-padding: 4 10 4 10;"/>

        <Button text="＋  Créer événement" onAction="#onAddEvent"
                style="-fx-background-color: linear-gradient(to right, #a855f7, #ec4899);
                       -fx-text-fill: #0a0a0f; -fx-font-family: 'Courier New';
                       -fx-font-weight: bold; -fx-font-size: 13px;
                       -fx-background-radius: 6; -fx-padding: 10 22 10 22; -fx-cursor: hand;"/>
    </HBox>

    <!-- Tableau -->
    <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 24 40 40 40;">
        <VBox style="-fx-background-color: #111122; -fx-border-color: #1a1a2e;
                     -fx-border-width: 1; -fx-border-radius: 10; -fx-background-radius: 10;"
              VBox.vgrow="ALWAYS">

            <HBox style="-fx-padding: 14 20 14 20;
                         -fx-background-color: rgba(255,255,255,0.02);
                         -fx-border-color: transparent transparent #1a1a2e transparent;
                         -fx-border-width: 0 0 1 0; -fx-background-radius: 10 10 0 0;">
                <Label text="ID"           minWidth="50"  style="-fx-text-fill: #444455; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-letter-spacing: 2px;"/>
                <Label text="NOM"          minWidth="200" style="-fx-text-fill: #444455; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-letter-spacing: 2px;"/>
                <Label text="DATE"         minWidth="110" style="-fx-text-fill: #444455; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-letter-spacing: 2px;"/>
                <Label text="LIEU"         minWidth="160" style="-fx-text-fill: #444455; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-letter-spacing: 2px;"/>
                <Label text="PARTICIPANTS" minWidth="110" style="-fx-text-fill: #444455; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-letter-spacing: 2px;"/>
                <Label text="STATUT"       minWidth="100" style="-fx-text-fill: #444455; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-letter-spacing: 2px;"/>
                <Label text="ACTIONS"      style="-fx-text-fill: #444455; -fx-font-family: 'Courier New'; -fx-font-size: 11px; -fx-letter-spacing: 2px;"/>
            </HBox>

            <TableView fx:id="tableEvents" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: transparent; -fx-border-color: transparent;
                              -fx-table-cell-border-color: #1a1a2e;
                              -fx-font-family: 'Courier New'; -fx-font-size: 13px;">
                <columns>
                    <TableColumn fx:id="colId"           text="ID"           prefWidth="50"/>
                    <TableColumn fx:id="colNom"          text="NOM"          prefWidth="200"/>
                    <TableColumn fx:id="colDate"         text="DATE"         prefWidth="110"/>
                    <TableColumn fx:id="colLieu"         text="LIEU"         prefWidth="160"/>
                    <TableColumn fx:id="colParticipants" text="PARTICIPANTS"  prefWidth="110"/>
                    <TableColumn fx:id="colStatut"       text="STATUT"       prefWidth="100"/>
                    <TableColumn fx:id="colActions"      text="ACTIONS"      prefWidth="240"/>
                </columns>
                <placeholder>
                    <Label text="Aucun événement trouvé."
                           style="-fx-text-fill: #444455; -fx-font-family: 'Courier New'; -fx-font-size: 13px;"/>
                </placeholder>
            </TableView>
        </VBox>
    </VBox>
</VBox>
